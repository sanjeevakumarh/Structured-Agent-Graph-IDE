{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5100"
      }
    }
  },
  "SAGIDE": {
    "PromptsPath": "../../prompts",
    "SkillsPath": "../../skills",
    "Scheduler": {
      "Enabled": true
    },
    "Database": {
      "Path": "",
      "DlqRetentionDays": 7
    },
    "Communication": {
      "MaxMessageSizeBytes": 10485760,
      "MaxBroadcastQueueSize": 10000,
      "BroadcastAllTasks": true
    },
    "Orchestration": {
      "MaxTaskHistoryInMemory": 1000,
      "BroadcastThrottleMs": 200,
      "MaxFileSizeChars": 32000,
      "WebApiBatchMaxItems": 50,
      "WebSearchBatchMaxItems": 20
    },
    "Caching": {
      "OutputCacheEnabled": false,
      "SearchCacheTtlMinutes": 0,
      "HealthPollIntervalSeconds": 30,
      "RoutingHintsTtlSeconds": 60,
      "PersistentSearchCacheTtlHours": 0,
      "SearchCacheRetentionDays": 30,
      "SearchCacheTtlByDomain": {
        "finance": 24,
        "research": 168,
        "robotics": 168,
        "notes": 720
      }
    },
    "RunTracing": {
      "Enabled": true,
      "Path": "~/reports/traces"
    },
    "Providers": {
      "Claude": { "MaxTokens": 4096 },
      "Gemini": { "MaxTokens": 4096 },
      "Codex": { "MaxTokens": 16384 },
      "Ollama": { "MaxTokens": 4096 }
    },
    "Notes": {
      "Enabled": true,
      "GraphPath": "<logseq path>",
      "Schedule": "0 0 * * *",
      "FilePatterns": ["*.md"],
      "ExcludeFolders": ["logseq", ".git", "assets", "node_modules"],
      "SourceTag": "logseq_notes",
      "TaskMarkers": ["TODO", "DOING", "LATER", "NOW", "NEXT", "IN-PROGRESS"],
      "SummaryModel": "openai/gpt-oss-120b@gmkmini",
      "SummaryModelFallback": "ollama/qwen3:30b-a3b@workstation"
    },
    "Rag": {
      "SearchEngines": "",
      "EmbeddingBatchSize": 32,
      "ChunkSize": 1500,
      "ChunkOverlap": 200,
      "CacheTtlHours": 4,
      "RateLimitDelayMs": 1000
    },
    "NamedPipeName": "SAGIDEPipe",
    "BuiltInTemplatesPath": "Orchestrator/Templates",
    "MaxConcurrentAgents": 5,
    "ApiKeys": {
      "Anthropic": "sk-",
      "OpenAI": "sk-",
      "Google": "AI"
    },
    "Ollama": {
      "Servers": [
        {
          "Name": "workstation",
           "BaseUrl": "http://localhost:11434",
          "RagOrder": 0,
           "SearchUrl": "http://localhost:8080",
          "Models": [
            "qwen3-coder:30b",
            "qwen3:30b-a3b",
            "qwen2.5-coder:14b-instruct-q4_K_M",
            "qwen2.5:14b-instruct-q4_K_M",
            "mistral-small3.1:24b-instruct-2503-q4_K_M",
            "nomic-embed-text:latest"
          ]
        },
        {
          "Name": "localhost",
          "BaseUrl": "http://localhost:11434",
          "RagOrder": 3,
          "SearchUrl": "http://localhost:8888",
          "Models": [
            "qwen2.5-coder:7b-instruct-q4_K_M",
            "qwen2.5:7b-instruct-q4_K_M",
            "llama3.2:3b-instruct-q8_0",
            "nomic-embed-text:latest"
          ]
        },
        {
          "Name": "mini",
           "BaseUrl": "http://localhost:11434",
          "RagOrder": 2,
           "SearchUrl": "http://localhost:8080",
          "Models": [
            "qwen2.5-coder:7b-instruct-q6_K",
            "Qwen3.5:9b",
            "qwen2.5:14b-instruct-q4_K_M",
            "gemma2:9b-instruct-q4_K_M",
            "nomic-embed-text:latest"
          ]
        },
        {
          "Name": "edge",
           "BaseUrl": "http://localhost:11434",
          "Models": [
            "Qwen2.5-Coder:3b",
            "qwen3.5:4b",
            "gemma3:4b"
          ]
        }
      ]
    },
    "OpenAICompatible": {
      "Servers": [
        {
          "Name": "gmkmini",
           "BaseUrl": "http://localhost:11434",
           "SearchUrl": "http://localhost:8080",
          "Models": [
            "gpt-oss-120b",
            "qwen3-coder-next",
            "text-embedding-nomic-embed-text-v1.5"
          ]
        },
        {
          "Name": "orin",
           "BaseUrl": "http://localhost:8000"
        }
      ]
    },
    "Timeouts": {
      "NamedPipeRequestMs": 7200000,
      "HealthCheckMs": 7200000,
      "PipeReconnectMs": 3000,
      "PipeReconnectMaxMs": 7200000,
      "TaskExecutionMs": 7200000,
      "Providers": {
        "Claude": 7200000,
        "Codex": 7200000,
        "Gemini": 7200000,
        "Ollama": 7200000
      }
    },
    "Git": {
      "AutoCommitResults": false,
      "Branch": "sag-agent-log"
    },
    "AgentLimits": {
      "Agents": {
        "CodeReview": {
          "MaxIterations": 5
        },
        "TestGeneration": {
          "MaxIterations": 5
        },
        "Refactoring": {
          "MaxIterations": 5
        },
        "Debug": {
          "MaxIterations": 5
        },
        "Documentation": {
          "MaxIterations": 5
        },
        "SecurityReview": {
          "MaxIterations": 3
        }
      }
    },
    "Routing": {
      "QualitySamplingEnabled": true,
      "SamplingRate": 0.25,
      "QualityProbeAllowlist": ["ollama/qwen3:30b-a3b", "openai/gpt-oss-120b"],
      "Capabilities": {
        "fast_general": "ollama/qwen3:30b-a3b@workstation",
        "deep_analyst": "openai/gpt-oss-120b@gmkmini",
        "coder": "openai/qwen3-coder-next@gmkmini",
        "extractor": "ollama/qwen3:30b-a3b@workstation",
        "critic": "ollama/qwen3.5:4b@edge"
      }
    },
    "QualityScoring": {
      "Enabled": true,
      "Mode": "workflow",
      "ScoringModel": "ollama/qwen2.5:7b-instruct-q4_K_M@localhost",
      "FallbackScoringModel": "ollama/qwen3.5:4b@edge"
    },
    "WorkflowPolicy": {
      "Enabled": true,
      "ProtectedPathPatterns": [
        "**/.env",
        "**/.env.*",
        "**/appsettings*.json",
        "**/secrets/**",
        "**/*.pfx",
        "**/*.pem",
        "**/*.key",
        "**/*.p12"
      ],
      "BlockedAgentTypes": [],
      "MaxStepsPerWorkflow": 50
    }
  }
}
