{
  "name": "sagide-logseq-plugin",
  "version": "0.1.0",
  "description": "SAGIDE plugin for Logseq",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx esbuild src/index.ts --bundle --platform=browser --target=es2020 --outfile=dist/index.js --external:@logseq/libs",
    "dev": "npx esbuild src/index.ts --bundle --platform=browser --target=es2020 --outfile=dist/index.js --external:@logseq/libs --watch"
  },
  "devDependencies": {
    "@logseq/libs": "^0.2.12",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  }
}